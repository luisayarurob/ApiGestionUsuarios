#!/usr/bin/env sh
# ----------------------------------------------------------------------------
# Maven Wrapper
# ----------------------------------------------------------------------------

PRG="$0"

# resolve links
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")"/$link"
  fi
done

SAVED="$(pwd)"
cd "$(dirname "$PRG")" >/dev/null
ROOT_DIR="$(pwd -P)"
cd "$SAVED" >/dev/null

JAVA_EXE="java"
if [ -n "$JAVA_HOME" ]; then
  if [ -x "$JAVA_HOME/bin/java" ]; then
    JAVA_EXE="$JAVA_HOME/bin/java"
  elif [ -x "$JAVA_HOME/java" ]; then
    JAVA_EXE="$JAVA_HOME/java"
  fi
fi

WRAPPER_JAR="$ROOT_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_MAIN_CLASS="org.apache.maven.wrapper.MavenWrapperMain"

exec "$JAVA_EXE" -cp "$WRAPPER_JAR" -Dmaven.multiModuleProjectDirectory="$ROOT_DIR" "$WRAPPER_MAIN_CLASS" "$@"
